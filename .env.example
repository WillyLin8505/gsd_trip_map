# Supabase — get from: Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key — get from: Supabase Dashboard -> Project Settings -> API -> project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER-ONLY, never expose to browser
# Get from: Supabase Dashboard -> Project Settings -> API -> project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase database connection string — SERVER-ONLY, used by Drizzle ORM
# Get from: Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI (use connection pooler / session string)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Google Maps JavaScript API key — browser-side, restricted to HTTP referrers (your domain) + Maps JavaScript API ONLY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-browser-maps-key

# Google Places / Routes API key — SERVER-ONLY, restricted to IP + Places API (New) + Routes API
# Never reference this from any client component — use only in server Route Handlers
GOOGLE_PLACES_API_KEY=your-server-places-key
